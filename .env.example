# Скопіюй цей файл у .env та встав свій ключ:
#   cp .env.example .env
#
# Ключ береться з Google AI Studio → https://aistudio.google.com/apikey
# .env читається автоматично (python-dotenv) у make_reference.py і generate.py.
# НЕ комітити .env і не ділитися ним — це секрет.

GEMINI_API_KEY=your-api-key-here
